{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile with roles.",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "createdAt": { "type": "number", "description": "Timestamp" }
      },
      "required": ["email", "createdAt"]
    },
    "Workflow": {
      "title": "Workflow",
      "description": "A workflow diagram consisting of nodes and edges.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "nodes": { "type": "array" },
        "edges": { "type": "array" },
        "createdAt": { "type": "number", "description": "Timestamp" },
        "updatedAt": { "type": "number", "description": "Timestamp" }
      },
      "required": ["userId", "nodes", "edges", "createdAt", "updatedAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Stores user profiles."
    },
    "/workflows/{workflowId}": {
      "schema": { "$ref": "#/entities/Workflow" },
      "description": "Stores workflows created by users."
    }
  }
}
